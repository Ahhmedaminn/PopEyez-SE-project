PORT=5050
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/popeyez_db
APP_URL=http://localhost:5173

# Optional real email delivery for guest invitations.
# If SMTP_HOST is missing, invitation emails are saved to backend/outbox as .eml files for local testing.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@popeyez.local
SMTP_FROM_NAME=PopEyez
